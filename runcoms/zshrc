# Source Prezto.
if [[ -s "${ZDOTDIR:-$HOME}/.zprezto/init.zsh" ]]; then
  source "${ZDOTDIR:-$HOME}/.zprezto/init.zsh"
fi

# Customize to your needs...

# History
HISTFILE=~/.histfile
HISTSIZE=5000
SAVEHIST=5000

# Editor
EDITOR=$(which vim)
GIT_EDITOR=$(which vim)
bindkey -v

# Completion
zstyle :compinstall filename '/Users/dave.thompson/.zshrc'
autoload -Uz compinit
compinit

# Aliases
alias gs="git status"
