# Source Prezto.
if [[ -s "${ZDOTDIR:-$HOME}/.zprezto/init.zsh" ]]; then
  source "${ZDOTDIR:-$HOME}/.zprezto/init.zsh"
fi

# Customize to your needs...

# ssh-agent
if [[ -z "${SSH_AUTH_SOCK}" ]]; then
  ssh-agent
fi

# Shell vars
HISTFILE=~/.histfile
HISTSIZE=5000
SAVEHIST=5000
EDITOR=/usr/bin/vim

# Exported vars
export GIT_EDITOR=/usr/bin/vim
export GOPATH=/Users/dave.thompson/code/golang
export PYCURL_SSL_LIBRARY=openssl

# Aliases
alias gs="git status"
alias kc="kubectl"
alias docker-killall='docker kill $(docker ps -q) &&  docker rm $(docker ps -a -q)'

# Functions
kconfig () {
  if [ -f $1 ]; then
    export KUBECONFIG="$1"
    echo "Switched to config \"$1\""
  else
    echo "config file not found"
    return 1
  fi  
}
kcontext () { kubectl config use-context "$1"; }

# PT
if [ -f ~/code/zsh-pt/.zshrc ]; then
  source ~/code/zsh-pt/.zshrc
fi
